# ProtonVPN Tailscale Exit Node - Environment Configuration
# Copy this file to .env and fill in your actual values

# ================================================
# ProtonVPN Configuration (Required)
# ================================================
# Get your WireGuard configuration from ProtonVPN:
# https://account.protonvpn.com/downloads#wireguard-configuration

# Your WireGuard private key (from ProtonVPN config file)
PROTON_WG_PRIVATE_KEY=your_private_key_here

# Your WireGuard public key (from ProtonVPN config file)
PROTON_WG_PUBLIC_KEY=your_public_key_here

# ProtonVPN WireGuard endpoint (server address)
# Example: nl-free-01.protonvpn.net:51820, jp-free-01.protonvpn.net:51820
PROTON_WG_ENDPOINT=nl-free-01.protonvpn.net:51820

# DNS server (ProtonVPN internal DNS)
PROTON_WG_DNS=10.8.0.1

# Your assigned WireGuard IP address
PROTON_WG_ADDRESS=10.8.0.2/32

# Allowed IPs (route all traffic through VPN)
PROTON_WG_ALLOWED_IPS=0.0.0.0/0,::/0

# ================================================
# Tailscale Configuration (Required)
# ================================================
# Generate an auth key at:
# https://login.tailscale.com/admin/settings/keys

# Tailscale authentication key (required)
TAILSCALE_AUTH_KEY=tskey-auth-your_key_here

# Hostname for this exit node in Tailscale network
TAILSCALE_HOSTNAME=proton-exit-node

# Additional routes to advertise (optional)
# Example: 10.0.0.0/24,192.168.1.0/24
TAILSCALE_ADVERTISE_ROUTES=

# Accept DNS from Tailscale (default: false)
TAILSCALE_ACCEPT_DNS=false

# Enable Tailscale SSH (default: true)
TAILSCALE_SSH=true

# Use userspace networking mode
TAILSCALE_USERSPACE_NETWORKING=false

# Tailscale port to listen on (default: 41641) using for UDP hole punching
TAILSCALE_PORT=41641

# ================================================
# Security Settings
# ================================================

# Enable kill switch (block traffic if VPN disconnects)
KILL_SWITCH=true

# Health check URL (to verify internet connectivity)
HEALTH_CHECK_URL=https://ipinfo.io

# Bypass STUN (UDP 3478) via eth0 for NAT traversal (default: true)
# Enables direct peer connections instead of DERP relay
BYPASS_STUN_VIA_ETH0=true

# Bypass Tailscale data port via eth0 for direct connections (default: true)
# Note: Peers in your tailnet will see your real IP (not ProtonVPN IP)
# Internet traffic still routes through ProtonVPN
BYPASS_TAILSCALE_PORT_VIA_ETH0=true

# ================================================
# Application Settings
# ================================================

# Rust backend API port
API_PORT=8080

# API bind address
API_HOST=0.0.0.0

# Frontend port
FRONTEND_PORT=3000

# Rust log level (error, warn, info, debug, trace)
RUST_LOG=info

# ================================================
# macvlan Network Configuration (Required)
# ================================================
# macvlan gives the container a direct LAN IP, bypassing Docker bridge NAT.
# This is required for UDP hole punching (direct Tailscale connections).
#
# NOTE: The host machine cannot directly access the container IP (Docker macvlan limitation).
#       Use `docker compose exec` or access via Tailscale instead.

# Host physical network interface (e.g., enp8s0, eth0)
# Find with: ip route show default | awk '{print $5}'
HOST_INTERFACE=enp8s0

# LAN subnet in CIDR notation
MACVLAN_SUBNET=10.196.1.0/24

# LAN gateway IP (usually your router)
MACVLAN_GATEWAY=10.196.1.1

# Static IP for the container (must be unused on your LAN and within MACVLAN_SUBNET)
CONTAINER_IP=10.196.1.200
